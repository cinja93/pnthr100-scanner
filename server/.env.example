# PNTHR Scanner v5.0 — Server Environment Variables
# Copy this to .env and fill in values
# NEVER commit .env to git

# ── REQUIRED (server will not function without these) ──────────────────────
JWT_SECRET=                    # Random 64+ char string for signing JWTs
MONGODB_URI=                   # MongoDB Atlas connection string (mongodb+srv://...)
FMP_API_KEY=                   # Financial Modeling Prep API key
ADMIN_EMAILS=                  # Comma-separated admin emails (e.g. scott@pnthrfunds.com)
API_KEY=                       # Random 32+ char string for API-key auth (bridge uses this)

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173   # Comma-separated origins (production: https://den.pnthrfunds.com,https://investor.pnthrfunds.com)

# ── DATABASE ───────────────────────────────────────────────────────────────
MONGODB_DB_NAME=pnthr100       # Database name (default: pnthr100)

# ── EMAIL (access request flow) ────────────────────────────────────────────
SMTP_HOST=                     # SMTP server hostname
SMTP_PORT=587                  # SMTP port (587 for TLS)
SMTP_USER=                     # SMTP username
SMTP_PASS=                     # SMTP password
APPROVAL_EMAIL=                # Admin email for approval notifications
FRONTEND_URL=https://den.pnthrfunds.com   # Base URL for email links

# ── AI GENERATION (Perch newsletter) ──────────────────────────────────────
ANTHROPIC_API_KEY=             # Anthropic API key for Claude

# ── ECONOMIC DATA ─────────────────────────────────────────────────────────
FRED_API_KEY=                  # FRED API key (optional — economic endpoints fail without it)

# ── IBKR BRIDGE FLAGS (all default to false) ──────────────────────────────
RECONCILIATION_CRON_ENABLED=false      # Master switch for every-minute reconciler
IBKR_AUTO_SYNC_STOPS=false             # Auto-sync protective stops to TWS
IBKR_AUTO_SYNC_LOT_TRIGGERS=false      # Auto-place/modify lot trigger BUY/SELL STOPs
IBKR_AUTO_CANCEL_ORPHANS=false         # Auto-cancel TWS stops for closed positions
IBKR_AUTO_CLOSE_GHOSTS=false           # Auto-close PNTHR positions when IBKR shows 0 shares
IBKR_AUTO_RECORD_ADD_FILLS=false       # Auto-record lot fills from IBKR executions
IBKR_AUTO_CATCH_UP=false               # Auto-fire catch-up market orders for missed lots
GHOST_THRESHOLD_MS=300000              # How long IBKR must show 0 shares before ghost-close (5 min)
